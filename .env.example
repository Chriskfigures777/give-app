# ─── GIVE APP — Environment Variables ───────────────────────────────────────
# Copy to .env.local for local dev.  On Vercel, add these in
# Project Settings → Environment Variables (Production / Preview / Development).
#
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.

# ── Supabase (https://supabase.com/dashboard/project/_/settings/api) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (https://dashboard.stripe.com/apikeys) ──
# Use sk_test_/pk_test_ for test mode, sk_live_/pk_live_ for production
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Platform plan subscription price IDs (created via POST /api/admin/setup-stripe-products)
STRIPE_GROWTH_PLAN_PRICE_ID=
STRIPE_PRO_PLAN_PRICE_ID=
STRIPE_TEAM_MEMBER_ADDON_PRICE_ID=

# ── App URLs ──
# REQUIRED for production: Auth emails (signup, password reset) use this for redirect links.
# Local: http://localhost:3000 | Production: https://your-domain.com
DOMAIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Footer GitHub link (e.g. https://github.com/your-org/give-app)
# NEXT_PUBLIC_GITHUB_URL=https://github.com
# Also configure Supabase Dashboard → Authentication → URL Configuration:
# Site URL = your production URL; Redirect URLs = https://your-domain.com/**

# ── Custom Domain Routing ──
# Comma-separated hosts for the main app (custom domain lookup skipped for these)
# SITE_APP_DOMAIN=give.app,www.give.app
# DNS CNAME target for custom domains (where org domains should point)
SITE_CNAME_TARGET=cname.vercel-dns.com
# NEXT_PUBLIC_SITE_CNAME_TARGET=cname.vercel-dns.com

# ── Eventbrite (for events feature) ──
# EVENTBRITE_CLIENT_ID=
# EVENTBRITE_CLIENT_SECRET=
# EVENTBRITE_REDIRECT_URI=http://localhost:3000/api/eventbrite/callback

# ── Pexels (optional — for media picker) ──
# PEXELS_API_KEY=

# ── Dwolla (ACH distribution for splits) ──
# DWOLLA_ENV=sandbox
# DWOLLA_KEY=
# DWOLLA_SECRET=
# DWOLLA_WEBHOOK_SECRET=

# ── Plaid (bank account linking via Dwolla Secure Exchange) ──
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# Redirect URI for Plaid OAuth (add to Plaid Dashboard → API → Allowed redirect URIs)
# PLAID_REDIRECT_URI=http://localhost:3000/api/plaid/callback

# ── Astra (credit card processor — https://dashboard-sandbox.astra.finance) ──
# ASTRA_CLIENT_ID=
# ASTRA_CLIENT_SECRET=   # Also used for webhook verification
# NEXT_PUBLIC_ASTRA_CLIENT_ID=   # For Astra Web SDK (client-side)

# ── Brevo (email campaigns — https://brevo.com) ──
# BREVO_API_KEY=xkeysib-xxx   # Or base64-encoded for MCP

# ── Resend (transactional + campaigns — https://resend.com) ──
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Give <noreply@yourdomain.com>
# For email campaigns (load-resend-campaigns.mjs --broadcasts):
# RESEND_SEGMENT_ID=xxx   # Create in Resend Dashboard → Audiences → Segments

# ── GoDaddy (domain search & buying) ──
# GODADDY_API_KEY=
# GODADDY_API_SECRET=

# ── AWS Route 53 (DNS hosting) ──
# AWS_ROUTE53_ACCESS_KEY_ID=
# AWS_ROUTE53_SECRET_ACCESS_KEY=
# AWS_ROUTE53_REGION=us-east-1

# ── AWS Static Site Hosting (S3 + CloudFront) ──
# Run: node scripts/setup-aws-hosting.mjs to create these resources
# AWS_HOSTING_BUCKET=give-published-sites
# AWS_CLOUDFRONT_DISTRIBUTION_ID=
# AWS_CLOUDFRONT_DOMAIN=d1234abcdef.cloudfront.net
# NEXT_PUBLIC_CLOUDFRONT_DOMAIN=d1234abcdef.cloudfront.net
# Optional: separate credentials for hosting (falls back to AWS_ROUTE53_* keys)
# AWS_HOSTING_ACCESS_KEY_ID=
# AWS_HOSTING_SECRET_ACCESS_KEY=
# AWS_HOSTING_REGION=us-east-1

# ── Auth0 (for Unit banking) ──
# When set, banking uses Auth0 JWT instead of Supabase. Unit validates via Auth0 JWKS.
# Create API in Auth0 Dashboard → APIs; use its identifier as NEXT_PUBLIC_AUTH0_BANKING_AUDIENCE
# so getAccessTokenSilently returns a JWT with sub for Unit.
# AUTH0_DOMAIN=dev-xxxx.us.auth0.com
# AUTH0_CLIENT_ID=your_auth0_client_id
# AUTH0_CLIENT_SECRET=your_auth0_client_secret
# AUTH0_AUDIENCE=https://dev-xxxx.us.auth0.com/api/v2/   ← for machine-to-machine token API
# NEXT_PUBLIC_AUTH0_DOMAIN=dev-xxxx.us.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=your_auth0_client_id
# NEXT_PUBLIC_AUTH0_BANKING_AUDIENCE=https://unit-banking   ← Auth0 API identifier for JWT

# ── Unit Banking (unit.co white-label) ──
# API token from Unit Dashboard → Settings → API Tokens (server-side customer creation)
# UNIT_API_TOKEN=v2_your_unit_api_token
# UNIT_API_URL=https://api.s.unit.sh   ← sandbox; use https://api.unit.co for production
# UNIT_ORG_ID=1   ← Positive integer (e.g. 1, 12345). Required for create-customer API. Find in Unit Dashboard.
# Shared secret — paste here AND in Unit Dashboard → Settings → Callback Endpoints
# (Unit will send: Authorization: Bearer <UNIT_WEBHOOK_SECRET> on every callback)
# UNIT_WEBHOOK_SECRET=your-unit-webhook-secret
# Custom Builder: set true to use components.js (Custom Build) instead of components-extended.js (Fast build)
# NEXT_PUBLIC_UNIT_CUSTOM_BUILDER=true

# ── Dev / Testing ──
# SKIP_WEBHOOK_VERIFICATION=true
# CONNECT_SYNC_SECRET=your-secret
